# Quant Evo Next-Gen
# This file is for the local bootstrap stack, not the final production topology.
# Copy this file to `.env` and fill the required values.

QE_ENV=development
QE_REPO_ROOT=/workspace
QE_NODE_ROLE=core
QE_DEPLOYMENT_TOPOLOGY=single_node_bootstrap
QE_OPERATOR_LANGUAGE=zh-CN
QE_OPERATOR_TIMEZONE=Asia/Hong_Kong
QE_MARKET_TIMEZONE=America/New_York
QE_MARKET_CALENDAR=XNYS
QE_DEFAULT_BROKER_PROVIDER_KEY=paper-sim
QE_DEFAULT_BROKER_ACCOUNT_REF=paper-main
QE_DEFAULT_BROKER_ENVIRONMENT=paper
QE_DEFAULT_BROKER_ADAPTER=paper_sim
QE_DEFAULT_ALLOCATION_POLICY_KEY=paper-default

# Alpaca broker
# Keep the default broker on `paper_sim` until you want real broker sync/execution.
# You can use shared credentials or per-environment credentials.
QE_ALPACA_API_KEY=
QE_ALPACA_API_SECRET=
QE_ALPACA_PAPER_API_KEY=
QE_ALPACA_PAPER_API_SECRET=
QE_ALPACA_LIVE_API_KEY=
QE_ALPACA_LIVE_API_SECRET=
QE_ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
QE_ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
QE_ALPACA_TIMEOUT_SECONDS=30

# API
QE_API_HOST=0.0.0.0
QE_API_PORT=8000
QE_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
QE_POSTGRES_URL=postgresql+psycopg://quant_evo:quant_evo@postgres:5432/quant_evo
QE_DB_BOOTSTRAP_ON_START=true
QE_DB_ECHO=false

# Discord
QE_DISCORD_TOKEN=
QE_DISCORD_GUILD_ID=
QE_DISCORD_CONTROL_CHANNEL=control
QE_DISCORD_CONTROL_CHANNEL_ID=
QE_DISCORD_APPROVALS_CHANNEL=approvals
QE_DISCORD_APPROVALS_CHANNEL_ID=
QE_DISCORD_ALERTS_CHANNEL=alerts
QE_DISCORD_ALERTS_CHANNEL_ID=
QE_DISCORD_ALLOWED_USER_IDS=

# OpenAI / Codex
# If you use a third-party OpenAI-compatible relay, fill both QE_OPENAI_API_KEY
# and QE_OPENAI_BASE_URL so Codex/Codex-compatible workers can route through it.
# The runner exports that key as both OPENAI_API_KEY and CODEX_API_KEY for Codex CLI.
QE_OPENAI_API_KEY=
QE_OPENAI_BASE_URL=
QE_PRIMARY_MODEL=gpt-5
QE_FAST_MODEL=gpt-5-mini
QE_CODEX_COMMAND=codex
QE_CODEX_DEFAULT_MODEL=gpt-5.3-codex
QE_CODEX_TIMEOUT_SECONDS=1800
QE_CODEX_WORKSPACE_MODE=isolated_copy

# Runtime
QE_HEARTBEAT_INTERVAL_SECONDS=60
QE_DASHBOARD_TITLE=Quant Evo Terminal

# Dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
QE_DASHBOARD_ACCESS_USERNAME=
QE_DASHBOARD_ACCESS_PASSWORD=
QE_DASHBOARD_API_TOKEN=
