[Unit]
Description=Quant Evo Core Stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/quant-evo-nextgen
ExecStart=/opt/quant-evo-nextgen/ops/bin/core-up.sh
ExecStop=/opt/quant-evo-nextgen/ops/bin/core-down.sh
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
