QE_ENV=production
QE_REPO_ROOT=/workspace
QE_NODE_ROLE=worker
QE_DEPLOYMENT_TOPOLOGY=two_vps_asymmetrical
QE_DEPLOYMENT_MARKET_MODE=us
QE_OPERATOR_LANGUAGE=zh-CN
QE_OPERATOR_TIMEZONE=Asia/Hong_Kong
QE_MARKET_TIMEZONE=America/New_York
QE_MARKET_CALENDAR=XNYS

# Point the worker at the Core VPS Postgres address or private network IP.
QE_POSTGRES_URL=postgresql+psycopg://quant_evo:change-me-now@CORE_VPS_IP:5432/quant_evo
QE_DB_BOOTSTRAP_ON_START=false
QE_DB_ECHO=false

QE_OPENAI_API_KEY=
QE_OPENAI_BASE_URL=
QE_PRIMARY_MODEL=gpt-5
QE_FAST_MODEL=gpt-5-mini
QE_CODEX_COMMAND=codex
QE_CODEX_DEFAULT_MODEL=gpt-5.3-codex
QE_CODEX_TIMEOUT_SECONDS=1800
QE_CODEX_WORKSPACE_MODE=isolated_copy
QE_SEARXNG_BASE_URL=
QE_RSSHUB_BASE_URL=
QE_PLAYWRIGHT_BROWSER_ENABLED=false
QE_PLAYWRIGHT_BROWSER_ENDPOINT=
QE_SKILL_LIBRARY_ROOT=skills

QE_HEARTBEAT_INTERVAL_SECONDS=60
QE_DASHBOARD_TITLE=EvoQ Terminal
