QE_ENV=production
QE_REPO_ROOT=/workspace
QE_NODE_ROLE=core
# Use `single_vps_compact` for the one-VPS product path.
QE_DEPLOYMENT_TOPOLOGY=two_vps_asymmetrical
# `us` enables US equities + US options. `cn` enables the A-share product surface.
QE_DEPLOYMENT_MARKET_MODE=us
QE_OPERATOR_LANGUAGE=zh-CN
QE_OPERATOR_TIMEZONE=Asia/Hong_Kong
QE_MARKET_TIMEZONE=America/New_York
QE_MARKET_CALENDAR=XNYS

QE_DEFAULT_BROKER_PROVIDER_KEY=paper-sim
QE_DEFAULT_BROKER_ACCOUNT_REF=paper-main
QE_DEFAULT_BROKER_ENVIRONMENT=paper
QE_DEFAULT_BROKER_ADAPTER=paper_sim
QE_DEFAULT_ALLOCATION_POLICY_KEY=paper-default

# Switch these after the first clean paper-mode deploy and the first successful Alpaca broker sync.
# QE_DEFAULT_BROKER_PROVIDER_KEY=alpaca-paper
# QE_DEFAULT_BROKER_ACCOUNT_REF=paper-main
# QE_DEFAULT_BROKER_ENVIRONMENT=paper
# QE_DEFAULT_BROKER_ADAPTER=alpaca

QE_POSTGRES_DB=quant_evo
QE_POSTGRES_USER=quant_evo
QE_POSTGRES_PASSWORD=change-me-now
QE_POSTGRES_BIND_HOST=127.0.0.1
QE_POSTGRES_HOST_PORT=5432
QE_POSTGRES_URL=postgresql+psycopg://quant_evo:change-me-now@postgres:5432/quant_evo
QE_DB_BOOTSTRAP_ON_START=false
QE_DB_ECHO=false

QE_API_BIND_HOST=127.0.0.1
QE_API_HOST_PORT=8000
QE_DASHBOARD_BIND_HOST=127.0.0.1
QE_DASHBOARD_HOST_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
QE_DASHBOARD_ACCESS_USERNAME=owner
QE_DASHBOARD_ACCESS_PASSWORD=
QE_DASHBOARD_API_TOKEN=
QE_EDGE_PUBLIC_HOST=
QE_EDGE_ACME_EMAIL=

QE_DISCORD_TOKEN=
QE_DISCORD_GUILD_ID=
QE_DISCORD_CONTROL_CHANNEL=control
QE_DISCORD_CONTROL_CHANNEL_ID=
QE_DISCORD_APPROVALS_CHANNEL=approvals
QE_DISCORD_APPROVALS_CHANNEL_ID=
QE_DISCORD_ALERTS_CHANNEL=alerts
QE_DISCORD_ALERTS_CHANNEL_ID=
QE_DISCORD_ALLOWED_USER_IDS=

QE_OPENAI_API_KEY=
QE_OPENAI_BASE_URL=
QE_PRIMARY_MODEL=gpt-5
QE_FAST_MODEL=gpt-5-mini
QE_CODEX_COMMAND=codex
QE_CODEX_DEFAULT_MODEL=gpt-5.3-codex
QE_CODEX_TIMEOUT_SECONDS=1800
QE_CODEX_WORKSPACE_MODE=isolated_copy
QE_SEARXNG_BASE_URL=
QE_RSSHUB_BASE_URL=
QE_PLAYWRIGHT_BROWSER_ENABLED=false
QE_PLAYWRIGHT_BROWSER_ENDPOINT=
QE_SKILL_LIBRARY_ROOT=skills

QE_ALPACA_PAPER_API_KEY=
QE_ALPACA_PAPER_API_SECRET=
QE_ALPACA_LIVE_API_KEY=
QE_ALPACA_LIVE_API_SECRET=
QE_ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
QE_ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
QE_ALPACA_TIMEOUT_SECONDS=30
QE_ALPACA_SYNC_LOOKBACK_DAYS=14

QE_HEARTBEAT_INTERVAL_SECONDS=60
QE_DASHBOARD_TITLE=EvoQ Terminal
